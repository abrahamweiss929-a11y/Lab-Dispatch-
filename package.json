    "seed-live-data": "NODE_OPTIONS=\"--conditions=react-server\" tsx --env-file=.env.local scripts/seed-live-data.ts",
    "apply-rls-policies": "tsx scripts/apply-rls-policies.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@supabase/ssr": "^0.10.2",
    "@supabase/supabase-js": "^2.104.0",
    "@types/mapbox-gl": "^3.4.1",
    "mapbox-gl": "^3.22.0",
    "next": "^14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "server-only": "^0.0.1",
    "twilio": "^5.13.1"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.4.6",
    "@testing-library/react": "^16.0.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
