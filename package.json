    "autoprefixer": "^10.4.19",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.5",
    "jsdom": "^24.1.0",
    "postcss": "^8.4.39",
    "tailwindcss": "^3.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.5.3",
    "vite": "^5.4.21",
    "vitest": "^1.6.0"
